<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/header_gradient"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔐" android:textSize="40sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="أدوات كلمات المرور" android:textColor="#FFF" android:textSize="22sp"
                android:textStyle="bold" android:layout_marginTop="8dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="تحليل، توليد، وتجزئة كلمات المرور" android:textColor="#C9A961" android:textSize="13sp" />
        </LinearLayout>

        <EditText android:id="@+id/password_input" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="أدخل كلمة مرور..."
            android:background="#FFF" android:padding="14dp" android:layout_marginBottom="8dp"
            android:fontFamily="monospace" />

        <EditText android:id="@+id/gen_length" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="طول كلمة المرور المولّدة (16)"
            android:inputType="number" android:background="#FFF" android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_analyze" android:layout_width="0dp"
                android:layout_height="45dp" android:layout_weight="1"
                android:text="📊 تحليل" android:textColor="#FFF" android:backgroundTint="#1976D2"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btn_generate" android:layout_width="0dp"
                android:layout_height="45dp" android:layout_weight="1"
                android:text="🔑 توليد" android:textColor="#FFF" android:backgroundTint="#4CAF50"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btn_hash" android:layout_width="0dp"
                android:layout_height="45dp" android:layout_weight="1"
                android:text="# تجزئة" android:textColor="#FFF" android:backgroundTint="#FF9800"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btn_clear_pw" android:layout_width="0dp"
                android:layout_height="45dp" android:layout_weight="1"
                android:text="🗑" android:textColor="#FFF" android:backgroundTint="#FF5722" />
        </LinearLayout>

        <ScrollView android:layout_width="match_parent" android:layout_height="300dp"
            android:background="#1A1A1A" android:layout_marginTop="8dp">
            <TextView android:id="@+id/password_result" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#00FF41"
                android:textSize="13sp" android:fontFamily="monospace"
                android:padding="12dp" android:textIsSelectable="true" android:lineSpacingExtra="2dp" />
        </ScrollView>
    </LinearLayout>
</ScrollView>
