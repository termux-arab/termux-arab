<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp"
            android:background="@drawable/header_gradient"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="📱"
                android:textSize="32sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تيرمكس العرب"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 أداة"
                    android:textColor="#C9A961"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_terminal"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="💻 الطرفية"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0F4C2A"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_about"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="ℹ️ حول"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:layout_marginEnd="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_vuln_scanner"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="🛡️ مكتشف الثغرات"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_vuln_db"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="📚 قاعدة الثغرات"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7B1FA2"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_network_scanner"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="🌐 ماسح الشبكة"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_system_monitor"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="📊 مراقب النظام"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00838F"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_password_tools"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="🔐 كلمات مرور"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E65100"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_http_tester"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="🌐 اختبار HTTP"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4527A0"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_github"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🐙 GitHub - تواصل بحسابك"
            android:textColor="#FFFFFF"
            android:backgroundTint="#24292E"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_packages"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📦 مدير الحزم - 50+ أداة"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00695C"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📂 الفئات"
            android:textColor="#1A1A1A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categories_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
