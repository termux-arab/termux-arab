<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/header_gradient"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌐" android:textSize="40sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ماسح الشبكات" android:textColor="#FFF" android:textSize="22sp"
                android:textStyle="bold" android:layout_marginTop="8dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="افحص المنافذ المفتوحة على أي مضيف" android:textColor="#C9A961" android:textSize="13sp" />
        </LinearLayout>

        <EditText android:id="@+id/host_input" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="المضيف (مثل: 192.168.1.1 أو google.com)"
            android:background="#FFF" android:padding="14dp" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <EditText android:id="@+id/port_start" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="من منفذ" android:inputType="number"
                android:background="#FFF" android:padding="14dp" android:layout_marginEnd="4dp" />
            <EditText android:id="@+id/port_end" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="إلى منفذ" android:inputType="number"
                android:background="#FFF" android:padding="14dp" />
        </LinearLayout>

        <Button android:id="@+id/btn_scan_network" android:layout_width="match_parent"
            android:layout_height="50dp" android:text="🚀 بدء الفحص"
            android:textColor="#FFF" android:textSize="16sp" android:textStyle="bold"
            android:backgroundTint="#0F4C2A" android:layout_marginBottom="16dp" />

        <ProgressBar android:id="@+id/scan_network_progress" android:layout_width="match_parent"
            android:layout_height="6dp" android:visibility="gone"
            style="?android:attr/progressBarStyleHorizontal" android:max="100" />

        <TextView android:id="@+id/scan_network_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#666" android:textSize="12sp"
            android:gravity="center" android:visibility="gone" android:layout_marginBottom="8dp" />

        <LinearLayout android:id="@+id/scan_results" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
